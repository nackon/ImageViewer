{
  "productName": "ImageViewer",
  "version": "0.1.0",
  "identifier": "com.example.imageviewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg", "png", "gif", "bmp", "webp"],
        "name": "Image",
        "role": "Viewer"
      }
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ImageViewer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}
